set -euo pipefail

CONFIG_FILE="${HOME}/.config/borg-backup/excludes"
REPO_FILE="${HOME}/.config/borg-backup/repo"

if [[ -f "$REPO_FILE" ]]; then
    BASE_REPO=$(cat "$REPO_FILE")
else
    BASE_REPO="${HOME}/backup/repos"
fi

# --- Date formatting ---

DAY_NAME=$(date +%A)
DAY_NUM=$(date +%-d)
MONTH_NAME_LOWER=$(date +%B | tr '[:upper:]' '[:lower:]')
YEAR=$(date +%y)

repo_is_unencrypted() {
    local repo="$1"
    local mode
    mode=$(sudo borg info --json "$repo" 2>/dev/null \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['encryption']['mode'])" 2>/dev/null \
        || echo "unknown")
    [[ "$mode" == "none" ]]
}

convert_repo_to_encrypted() {
    local repo="$1"
    local new_pass="$2"
    local tmp_repo="${repo}.encrypted-tmp"

    echo "  Converting $repo to encrypted..."
    mkdir -p "$tmp_repo"
    BORG_PASSPHRASE="$new_pass" sudo -E borg init --encryption=repokey "$tmp_repo"
    BORG_PASSPHRASE="" BORG_PASSPHRASE_NEW="$new_pass" sudo -E borg transfer \
        --from-repo "$repo" \
        "$tmp_repo" \
        || { echo "  Failed to transfer $repo, aborting conversion."; rm -rf "$tmp_repo"; return 1; }
    sudo rm -rf "$repo"
    sudo mv "$tmp_repo" "$repo"
    echo "  Converted $repo successfully."
}

prompt_new_passphrase() {
    read -rsp "Set passphrase for new repo (leave blank for none): " BORG_PASSPHRASE
    echo ""
    if [[ -n "$BORG_PASSPHRASE" ]]; then
        read -rsp "Confirm passphrase: " passphrase_confirm
        echo ""
        if [[ "$BORG_PASSPHRASE" != "$passphrase_confirm" ]]; then
            echo "Passphrases do not match, aborting."
            exit 1
        fi
    fi
    export BORG_PASSPHRASE
}

ensure_repo() {
    local repo="$1"
    if [[ ! -d "$repo" ]]; then
        echo "No repo found at $repo, initialising..."
        mkdir -p "$repo"
        prompt_new_passphrase
        if [[ -n "$BORG_PASSPHRASE" ]]; then
            sudo -E borg init --encryption=repokey "$repo"
        else
            sudo borg init --encryption=none "$repo"
        fi
    fi
}

prompt_source_dir() {
    read -rp "Directory to back up (e.g. /, /home, /usr/bin/): " SOURCE_DIR
    if [[ -z "$SOURCE_DIR" ]]; then
        echo "No directory entered, defaulting to /"
        SOURCE_DIR="/"
    fi
    if [[ ! -d "$SOURCE_DIR" ]]; then
        echo "Error: $SOURCE_DIR does not exist"
        exit 1
    fi
}

get_repo_for_source() {
    local source="$1"
    if [[ "$source" == "/" ]]; then
        echo "${BASE_REPO}/full-system-backup"
    else
        local relative="${source#/}"
        # Strip trailing slash so /home/ and /home both map to $BASE_REPO/home
        relative="${relative%/}"
        echo "${BASE_REPO}/${relative}"
    fi
}

prompt_archive_name() {
    echo "Default archive name: ${ARCHIVE_NAME}"
    read -rp "Use default? [y/n]: " choice
    if [[ "$choice" == "n" || "$choice" == "N" ]]; then
        read -rp "Enter archive name: " custom_name
        if [[ -z "$custom_name" ]]; then
            echo "No name entered, using default."
        else
            ARCHIVE_NAME="$custom_name"
        fi
    fi
}

set_repo() {
    local path="$1"
    ensure_config_dir
    echo "$path" > "$REPO_FILE"
    echo "Repo set to: $path"
}

prompt_passphrase() {
    if [[ -z "${BORG_PASSPHRASE:-}" ]]; then
        read -rsp "Passphrase for repo (press enter to skip): " BORG_PASSPHRASE
        echo ""
        export BORG_PASSPHRASE
    fi
}

change_password() {
    local new_pass="$1"
    read -rsp "Current passphrase (press enter if none): " old_pass
    echo ""

    while IFS= read -r -d '' config_file; do
        local repo
        repo=$(dirname "$config_file")
        echo "Processing $repo..."
        if repo_is_unencrypted "$repo"; then
            if [[ -n "$new_pass" ]]; then
                convert_repo_to_encrypted "$repo" "$new_pass"
            else
                echo "  Skipped $repo (already unencrypted, no passphrase given)"
            fi
        else
            BORG_PASSPHRASE="$old_pass" BORG_NEW_PASSPHRASE="$new_pass" sudo -E borg key change-passphrase "$repo" \
                || echo "  Failed to update passphrase for $repo"
        fi
    done < <(find "$BASE_REPO" -name "config" -print0)

    echo "Done."
}

get_ordinal() {
    local n=$1
    if (( n == 11 || n == 12 || n == 13 )); then echo "th"
    elif (( n % 10 == 1 )); then echo "st"
    elif (( n % 10 == 2 )); then echo "nd"
    elif (( n % 10 == 3 )); then echo "rd"
    else echo "th"
    fi
}

ORDINAL=$(get_ordinal "$DAY_NUM")
ARCHIVE_NAME="${DAY_NAME}-${DAY_NUM}${ORDINAL}-of-${MONTH_NAME_LOWER}-${YEAR}"

# --- Helper functions ---

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --exclude <path>     Add a path to the permanent exclude list"
    echo "  --dont-exclude <path>  Remove a path from the permanent exclude list"
    echo "  --list-excludes          Show all currently excluded paths"
    echo "  --help                   Show this help message"
    echo "  --repo <path>        Permanently store the repo base path"
    echo "Without any options, runs a backup with all configured excludes."
    echo "  --password <passkey>    Change the passphrase on all repo's"
    echo ""
    echo "Config file: $CONFIG_FILE"
    echo "Repository:  $BASE_REPO"
    echo "Archive name will be: $ARCHIVE_NAME"
    exit 0
}

ensure_config_dir() {
    local dir
    dir=$(dirname "$CONFIG_FILE")
    if [[ ! -d "$dir" ]]; then
        mkdir -p "$dir"
    fi
    if [[ ! -f "$CONFIG_FILE" ]]; then
        touch "$CONFIG_FILE"
    fi
}

exclude() {
    local path="$1"
    ensure_config_dir
    if grep -qxF "$path" "$CONFIG_FILE"; then
        echo "Already in exclude list: $path"
    else
        echo "$path" >> "$CONFIG_FILE"
        echo "Added to exclude list: $path"
    fi
}

dont_exclude() {
    local path="$1"
    ensure_config_dir
    if ! grep -qxF "$path" "$CONFIG_FILE"; then
        echo "Not found in exclude list: $path"
        return 1
    fi
    local tmpfile
    tmpfile=$(mktemp)
    grep -vxF "$path" "$CONFIG_FILE" > "$tmpfile" || true
    mv "$tmpfile" "$CONFIG_FILE"
    echo "Removed from exclude list: $path"
}

list_excludes() {
    ensure_config_dir
    echo "Current exclude list ($CONFIG_FILE):"
    echo "--------------------------------------"
    if [[ ! -s "$CONFIG_FILE" ]]; then
        echo "(empty — no excludes configured)"
    else
        cat "$CONFIG_FILE"
    fi
}

build_exclude_args() {
    ensure_config_dir
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue
        [[ "$line" == \#* ]] && continue
        printf '%s\0' "--exclude" "$line"
    done < "$CONFIG_FILE"
}

# --- Argument parsing ---

case "${1:-}" in
    --help)            usage ;;
    --exclude)
        if [[ -z "${2:-}" ]]; then echo "Error: --add-exclude requires a path argument"; exit 1; fi
        exclude "$2"; exit 0 ;;
    --dont-exclude)
        if [[ -z "${2:-}" ]]; then echo "Error: --remove-exclude requires a path argument"; exit 1; fi
        dont_exclude "$2"; exit 0 ;;
    --list-excludes)   list_excludes; exit 0 ;;
    --repo=*)
        set_repo "${1#--repo=}"; exit 0 ;;
    --repo)
        if [[ -z "${2:-}" ]]; then echo "Error: --repo requires a path argument"; exit 1; fi
        set_repo "$2"; exit 0 ;;
    --password=*)
        change_password "${1#--password=}"; exit 0 ;;
    --password)
        if [[ -z "${2:-}" ]]; then echo "Error: --password requires a new password argument"; exit 1; fi
        change_password "$2"; exit 0 ;;
    "")                : ;;
    *)                 echo "Unknown option: $1"; usage ;;
esac

# --- Run the backup ---
prompt_source_dir
REPO=$(get_repo_for_source "$SOURCE_DIR")
ensure_repo "$REPO"

echo "Starting backup: ${REPO}::${ARCHIVE_NAME}"
echo "Date: $(date)"
echo ""
echo "Excludes in effect:"

mapfile -d $'\0' EXCLUDE_ARGS < <(
    for path in \
        '/dev/*' '/proc/*' '/sys/*' '/tmp/*' '/run/*' \
        '/mnt/*' '/media/*' '/var/cache/*' '/var/tmp/*' \
        "${HOME}/.cache/*"; do
        printf '%s\0' "--exclude" "$path"
        echo "  [default] $path" >&2
    done
    build_exclude_args
)

echo ""

prompt_archive_name

prompt_passphrase
sudo -E borg create \
    --stats \
    --progress \
    "${REPO}::${ARCHIVE_NAME}" \
    "$SOURCE_DIR" \
    "${EXCLUDE_ARGS[@]}"
echo ""
echo "Backup complete: ${REPO}::${ARCHIVE_NAME}"
